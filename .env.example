# Volcengine Doubao Voice API credentials
# Get your API key from:
# https://console.volcengine.com/speech/new/setting/apikeys?projectName=default
VOLC_API_KEY=your_volcengine_api_key_here

# Resource ID for TTS (use the default value)
# VOLC_RESOURCE_ID=seed-tts-2.0

# Five cloned voice IDs (speaker IDs) from Volcengine voice cloning
# After cloning your voices in the console, replace these with the actual speaker IDs
VOICE_1_SPEAKER=replace_with_your_first_speaker_id
VOICE_2_SPEAKER=replace_with_your_second_speaker_id
VOICE_3_SPEAKER=replace_with_your_third_speaker_id
VOICE_4_SPEAKER=replace_with_your_fourth_speaker_id
VOICE_5_SPEAKER=replace_with_your_fifth_speaker_id
DEFAULT_VOICE_ID=cl-default

# Volcengine Doubao LLM credentials (for briefing generation)
# LLM API key may be different from TTS API key
LLM_API_KEY=your_llm_api_key_here
LLM_ENDPOINT_ID=your_llm_endpoint_id_here

# GitHub Pages deployment (git-based)
GIT_USER_NAME=Your Name
GIT_USER_EMAIL=your.email@example.com
GIT_REMOTE_URL=https://github.com/your-org/your-repo.git
GIT_BRANCH=gh-pages
